#!/bin/bash

# Script to get Azure credentials from GPG encrypted files
# Usage: get-cred [key|base|model|xyz_base|xyz_key] [filename.gpg]
# Default: get-cred key gpt.gpg

TYPE="${1:-key}"
FNAME="${2:-gpt.gpg}"
KEY_PATH="$HOME/deploy/keys/$FNAME"
OS_NAME="$(uname)"

if [ ! -f "$KEY_PATH" ]; then
    echo "Error: Key file $KEY_PATH not found." >&2
    exit 1
fi

case "$TYPE" in
    base)
        LINE=1
        ;;
    model)
        LINE=2
        ;;
    key)
        LINE=3
        ;;
    xyz_base)
        if [ "$OS_NAME" = "Darwin" ]; then
            LINE=6
        else
            LINE=4
        fi
        ;;
    xyz_key)
        if [ "$OS_NAME" = "Darwin" ]; then
            LINE=7
        else
            LINE=5
        fi
        ;;
    *)
        echo "Usage: $0 [base|model|key|xyz_base|xyz_key] [filename.gpg]" >&2
        exit 1
        ;;
esac

# Decrypt and extract the specific line
gpg -q --decrypt "$KEY_PATH" | sed -n "${LINE}p"

#!/bin/bash

# Script to get Azure credentials from GPG encrypted files
# Usage: get-cred [key|base|model|xyz_base|xyz_key|feishu_hook_id|feishu_secret|feishu_app_id|feishu_app_secret|feishu_chat_id|codex-hc-fte] [filename.gpg]
# Default: get-cred key gpt.gpg

TYPE="${1:-key}"
FNAME="${2:-gpt.gpg}"
KEY_PATH="$HOME/deploy/keys/$FNAME"
OS_NAME="$(uname)"

if [ ! -f "$KEY_PATH" ]; then
    echo "Error: Key file $KEY_PATH not found." >&2
    exit 1
fi

case "$TYPE" in
    base)
        LINE=1
        ;;
    model)
        LINE=2
        ;;
    key)
        LINE=3
        ;;
    xyz_base)
        if [[ -n "${LEVEL+x}" ]]; then
            LINE=$((LEVEL * 2 + 4))
        else
            TMUX_SESSION="$([ -n "$TMUX" ] && tmux display-message -p '#S' 2>/dev/null)"
            if [ "$TMUX_SESSION" = "learn" ] || [ "$OS_NAME" = "Darwin" ]; then
                LINE=4
            else
                LINE=6
            fi
        fi
        ;;
    xyz_key)
        if [[ -n "${LEVEL+x}" ]]; then
            LINE=$((LEVEL * 2 + 5))
        else
            TMUX_SESSION="$([ -n "$TMUX" ] && tmux display-message -p '#S' 2>/dev/null)"
            if [ "$TMUX_SESSION" = "learn" ] || [ "$OS_NAME" = "Darwin" ]; then
                LINE=5
            else
                LINE=7
            fi
        fi
        ;;
    feishu_hook_id)
        LINE=10
        ;;
    feishu_secret)
        LINE=11
        ;;
    feishu_app_id)
        LINE=12
        ;;
    feishu_app_secret)
        LINE=13
        ;;
    feishu_chat_id)
        LINE=14
        ;;
    codex-hc-fte)
        LINE=15
        ;;
    *)
        echo "Usage: $0 [base|model|key|xyz_base|xyz_key|feishu_hook_id|feishu_secret|feishu_app_id|feishu_app_secret|feishu_chat_id|codex-hc-fte] [filename.gpg]" >&2
        exit 1
        ;;
esac

# Decrypt and extract the specific line
gpg -q --decrypt "$KEY_PATH" | sed -n "${LINE}p"

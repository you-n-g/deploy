#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
source "$SCRIPT_DIR/../../configs/tmux/ai/lib.sh"

ROWS=$(_ai_window_rows -a)
if [[ -z "$ROWS" ]]; then
    echo "No AI agent windows found." >&2
    exit 1
fi

IFS=$'\n' read -r ROW _rest <<< "$ROWS"
IFS=$'\t' read -r _last_visit target _wname _window_id _pane_pid _activity_epoch _unread _running _attribute <<< "$ROW"

if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$target"
else
    exec tmux attach-session -t "${target%%:*}" \; select-window -t "$target"
fi

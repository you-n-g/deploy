#!/usr/bin/env bash
set -euo pipefail

check="${1:-}"
health_dir="$HOME/deploy/helper_scripts/health"

list_checks() {
  for script in "$health_dir"/*; do
    [ -e "$script" ] || continue
    [ -f "$script" ] || continue
    [ -x "$script" ] || continue
    basename "$script"
  done | sort
}

if [ -z "$check" ]; then
  list_checks | while IFS= read -r check_name; do
    echo "## health-check $check_name"
    "$health_dir/$check_name"
  done
  exit 0
fi

if [ "$check" = "list" ]; then
  list_checks
  exit 0
fi

script="$health_dir/$check"
if [ ! -x "$script" ]; then
  echo "FAIL: unknown health check: $check"
  exit 1
fi

exec "$script" "${@:2}"

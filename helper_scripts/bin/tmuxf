#!/usr/bin/env python3
import subprocess
import sys


def tmux_output(*args: str) -> str:
    return subprocess.run(
        ["tmux", *args],
        check=True,
        stdout=subprocess.PIPE,
        text=True,
    ).stdout


rows: list[str] = []
panes = tmux_output(
    "list-panes",
    "-a",
    "-F",
    "#{pane_id}\t#{session_name}:#{window_index}.#{pane_index}\t#{window_name}",
)

for pane_row in panes.splitlines():
    pane_id, pane_target, window_name = pane_row.split("\t", 2)
    content = tmux_output("capture-pane", "-p", "-t", pane_id)
    for line in content.splitlines():
        text = line.rstrip()
        if text:
            rows.append(f"{pane_id}\t{pane_target}\t{window_name}\t{text}")

try:
    selected = subprocess.run(
        [
            "fzf",
            "--delimiter",
            "\t",
            "--with-nth",
            "2..",
            "--preview",
            'tmux capture-pane -ept {1} | perl -0777 -pe "s/\\s+\\z/\\n/"',
            "--preview-window",
            "right:60%,follow",
        ],
        input="\n".join(rows),
        check=True,
        stdout=subprocess.PIPE,
        text=True,
    ).stdout.rstrip("\n")
except subprocess.CalledProcessError as exc:
    sys.exit(exc.returncode)

selected_pane = selected.split("\t", 1)[0] if selected else ""
if selected_pane:
    subprocess.run(["tmux", "switch-client", "-t", selected_pane], check=True)
    subprocess.run(["tmux", "select-pane", "-t", selected_pane], check=True)

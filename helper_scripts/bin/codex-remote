#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  codex-remote [options] SSH_TARGET [SSH_LOGIN_OPTIONS...]

Run Codex locally while using a Codex app-server on a remote SSH host.
The local TUI starts with approval, sandbox, and hook-trust bypasses by default.

Options:
  -C, --remote-cwd DIR       cd to DIR on the remote host before starting Codex
  -c, --config KEY=VALUE     override remote Codex config; may be repeated
      --local-port PORT      local forwarded port (default: pick a free port)
      --remote-port PORT     remote app-server port (default: same as the picked local port)
      --no-ai-status-bridge  do not bridge remote Codex hooks back to local tmux
      --codex-bin CMD        local Codex command (default: $CODEX_BIN or codex)
      --remote-codex-bin CMD remote Codex command (default: $REMOTE_CODEX_BIN or codex)
      --timeout SECONDS      wait for the remote app-server to become reachable (default: 20)
  -h, --help                 show this help

Examples:
  codex-remote -C /data/repo devbox
  codex-remote -C /data/repo -c 'model_provider="lb"' devbox
  codex-remote -C /data/repo user@10.0.0.8 -p 2222 -i ~/.ssh/id_ed25519
  codex-remote --local-port 4500 --remote-port 4500 devbox -J jumpbox

Notes:
  SSH_LOGIN_OPTIONS are passed to ssh before SSH_TARGET, so options such as
  -p, -i, -J, -F, and -o work even though they appear after SSH_TARGET here.
  -c/--config overrides are passed to both the remote app-server and the local
  TUI, after the local TUI mirrors the remote host's default Codex provider.
  Remote status hooks use $HOME/.codex-remote-status so Codex hook trust can
  persist across runs while the forwarded port is still picked automatically.
EOF
}

die() {
    echo "codex-remote: $*" >&2
    exit 1
}

need_arg() {
    local opt="$1"
    local value="${2:-}"
    [[ -n "$value" ]] || die "$opt requires an argument"
}

pick_free_port() {
    command -v python3 >/dev/null 2>&1 || die "python3 is required to pick a free local port; pass --local-port to avoid this"
    python3 - <<'PY'
import socket

with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
    s.bind(("127.0.0.1", 0))
    print(s.getsockname()[1])
PY
}

shell_quote() {
    printf "'%s'" "$(printf "%s" "$1" | sed "s/'/'\\\\''/g")"
}

probe_app_server_ws() (
    local port="$1"
    local response
    local ws_key="AAAAAAAAAAAAAAAAAAAAAA=="

    { exec 3<>"/dev/tcp/127.0.0.1/${port}"; } 2>/dev/null || return 1
    printf 'GET / HTTP/1.1\r\nHost: 127.0.0.1:%s\r\nConnection: Upgrade\r\nUpgrade: websocket\r\nSec-WebSocket-Key: %s\r\nSec-WebSocket-Version: 13\r\n\r\n' "$port" "$ws_key" >&3 || return 1
    IFS= read -r -t 2 response <&3 || return 1
    [[ "$response" == HTTP/*" 101 "* ]]
)

remote_cwd=""
local_port=""
remote_port=""
codex_bin="${CODEX_BIN:-codex}"
remote_codex_bin="${REMOTE_CODEX_BIN:-codex}"
connect_timeout="20"
ai_status_bridge=1
codex_config_overrides=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -C|--remote-cwd)
            need_arg "$1" "${2:-}"
            remote_cwd="$2"
            shift 2
            ;;
        -c|--config)
            need_arg "$1" "${2:-}"
            codex_config_overrides+=("$2")
            shift 2
            ;;
        --local-port)
            need_arg "$1" "${2:-}"
            local_port="$2"
            shift 2
            ;;
        --remote-port)
            need_arg "$1" "${2:-}"
            remote_port="$2"
            shift 2
            ;;
        --no-ai-status-bridge)
            ai_status_bridge=0
            shift
            ;;
        --codex-bin)
            need_arg "$1" "${2:-}"
            codex_bin="$2"
            shift 2
            ;;
        --remote-codex-bin)
            need_arg "$1" "${2:-}"
            remote_codex_bin="$2"
            shift 2
            ;;
        --timeout)
            need_arg "$1" "${2:-}"
            connect_timeout="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            die "unknown option before SSH_TARGET: $1"
            ;;
        *)
            break
            ;;
    esac
done

[[ $# -ge 1 ]] || {
    usage >&2
    exit 1
}

ssh_target="$1"
shift
ssh_args=("$@")

command -v ssh >/dev/null 2>&1 || die "ssh is not available"
command -v "$codex_bin" >/dev/null 2>&1 || die "local Codex command not found: $codex_bin"

if [[ -n "$remote_port" ]]; then
    [[ "$remote_port" =~ ^[0-9]+$ ]] || die "--remote-port must be numeric: $remote_port"
fi
[[ "$connect_timeout" =~ ^[0-9]+$ ]] || die "--timeout must be numeric: $connect_timeout"

if [[ -z "$local_port" ]]; then
    local_port="$(pick_free_port)"
fi
[[ "$local_port" =~ ^[0-9]+$ ]] || die "--local-port must be numeric: $local_port"

if [[ -z "$remote_port" ]]; then
    remote_port="$local_port"
fi

remote_listen="ws://127.0.0.1:${remote_port}"

log_file="$(mktemp -t codex-remote.XXXXXX.log)"
remote_script="$(mktemp -t codex-remote.XXXXXX.remote.sh)"
status_log_file=""
ssh_pid=""
status_bridge_pid=""
status_monitor_pid=""
status_bridge_enabled=0
local_status_port=""
remote_status_port=""
remote_app_server_pid=""
remote_app_server_ready=0
remote_cleanup_done=0
local_codex_config_args=()

load_remote_codex_config_overrides() {
    local output

    if ! output="$(ssh "${ssh_args[@]}" "$ssh_target" 'python3 - <<'"'"'PY'"'"'
import json
import re
import tomllib
from pathlib import Path

config_path = Path.home() / ".codex" / "config.toml"
if not config_path.exists():
    raise SystemExit(f"remote Codex config not found: {config_path}")

config = tomllib.loads(config_path.read_text())
provider = config.get("model_provider")
if not provider:
    raise SystemExit(0)
if not isinstance(provider, str) or not re.fullmatch(r"[A-Za-z0-9_-]+", provider):
    raise SystemExit(f"unsupported remote model_provider key: {provider!r}")

def emit(key, value):
    if value is None:
        return
    if isinstance(value, (str, int, float, bool)):
        print(f"{key}={json.dumps(value)}")

for key in (
    "model",
    "model_provider",
    "model_reasoning_effort",
    "model_reasoning_summary",
):
    emit(key, config.get(key))

providers = config.get("model_providers") or {}
provider_config = providers.get(provider) or {}
if not isinstance(provider_config, dict):
    raise SystemExit(f"remote model provider is not a table: {provider!r}")

emit(f"model_providers.{provider}.name", provider_config.get("name") or provider)
for key in (
    "base_url",
    "wire_api",
    "requires_openai_auth",
):
    emit(f"model_providers.{provider}.{key}", provider_config.get(key))
PY
')"; then
        die "failed to read remote Codex model provider from $ssh_target"
    fi

    while IFS= read -r override; do
        [[ -n "$override" ]] || continue
        local_codex_config_args+=(-c "$override")
    done <<<"$output"
}

append_config_overrides_for_local_tui() {
    local override

    for override in "${codex_config_overrides[@]}"; do
        local_codex_config_args+=(-c "$override")
    done
}

read_remote_app_server_state() {
    remote_app_server_pid="$(awk -F= '/^CODEX_REMOTE_APP_SERVER_PID=/ {print $2; exit}' "$log_file" 2>/dev/null || true)"
    if grep -q '^CODEX_REMOTE_APP_SERVER_READY=1$' "$log_file" 2>/dev/null; then
        remote_app_server_ready=1
    fi
}

cleanup_remote_app_server() {
    read_remote_app_server_state
    [[ -n "$remote_app_server_pid" ]] || return 0
    [[ "$remote_cleanup_done" = "0" ]] || return 0
    remote_cleanup_done=1

    local cleanup_script
    cleanup_script="
pid=$(shell_quote "$remote_app_server_pid")
listen=$(shell_quote "$remote_listen")
if [[ -r \"/proc/\$pid/cmdline\" ]] && tr '\0' ' ' <\"/proc/\$pid/cmdline\" | grep -F -- \"app-server --listen \$listen\" >/dev/null; then
    kill \"\$pid\" 2>/dev/null || true
fi
"
    # shellcheck disable=SC2029 # cleanup_script is intentionally built locally, then quoted for the remote shell.
    ssh "${ssh_args[@]}" "$ssh_target" "bash -lc $(shell_quote "$cleanup_script")" >/dev/null 2>&1 || true
}

cleanup() {
    cleanup_remote_app_server
    if [[ -n "$ssh_pid" ]] && kill -0 "$ssh_pid" 2>/dev/null; then
        kill "$ssh_pid" 2>/dev/null || true
        wait "$ssh_pid" 2>/dev/null || true
    fi
    if [[ -n "$status_bridge_pid" ]] && kill -0 "$status_bridge_pid" 2>/dev/null; then
        kill "$status_bridge_pid" 2>/dev/null || true
        wait "$status_bridge_pid" 2>/dev/null || true
    fi
    if [[ -n "$status_monitor_pid" ]] && kill -0 "$status_monitor_pid" 2>/dev/null; then
        kill "$status_monitor_pid" 2>/dev/null || true
        wait "$status_monitor_pid" 2>/dev/null || true
    fi
    rm -f "$log_file"
    rm -f "$remote_script"
    if [[ -n "$status_log_file" ]]; then
        rm -f "$status_log_file"
    fi
}
trap cleanup EXIT INT TERM

start_status_bridge() {
    [[ "$ai_status_bridge" = "1" ]] || return 0
    [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || return 0

    command -v tmux >/dev/null 2>&1 || die "tmux is required for the AI status bridge"

    local_status_port="$(pick_free_port)"
    remote_status_port="$local_status_port"
    status_log_file="$(mktemp -t codex-remote-status.XXXXXX.log)"

    CODEX_REMOTE_STATUS_PANE="$TMUX_PANE" \
    CODEX_REMOTE_STATUS_PORT="$local_status_port" \
    python3 - <<'PY' >"$status_log_file" 2>&1 &
import http.server
import os
import subprocess
import sys

pane = os.environ["CODEX_REMOTE_STATUS_PANE"]
port = int(os.environ["CODEX_REMOTE_STATUS_PORT"])
track_script = os.path.expanduser("~/deploy/configs/tmux/script/track_ai_agent_state.sh")
allowed_states = {"init", "running", "idle", "background", "pending"}


class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        state = self.path.split("?", 1)[0].strip("/")
        if state not in allowed_states:
            self.send_response(404)
            self.end_headers()
            return

        try:
            env = os.environ.copy()
            env["AI_AGENT_STATE_SOURCE"] = "codex-remote-status-bridge"
            subprocess.run(
                [track_script, state, pane],
                check=True,
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=sys.stderr,
            )
        except subprocess.CalledProcessError:
            self.send_response(500)
            self.end_headers()
            return

        self.send_response(204)
        self.end_headers()

    def log_message(self, _format, *_args):
        return


server = http.server.ThreadingHTTPServer(("127.0.0.1", port), Handler)
try:
    server.serve_forever()
except KeyboardInterrupt:
    sys.exit(0)
PY
    status_bridge_pid="$!"

    local deadline=$((SECONDS + connect_timeout))
    while ! bash -c "</dev/tcp/127.0.0.1/${local_status_port}" >/dev/null 2>&1; do
        if ! kill -0 "$status_bridge_pid" 2>/dev/null; then
            echo "codex-remote: AI status bridge exited before it became reachable" >&2
            cat "$status_log_file" >&2
            exit 1
        fi
        if (( SECONDS >= deadline )); then
            echo "codex-remote: timed out waiting for local AI status bridge on 127.0.0.1:${local_status_port}" >&2
            cat "$status_log_file" >&2
            exit 1
        fi
        sleep 0.2
    done

    AI_AGENT_STATE_SOURCE="codex-remote-status-bridge:init" "$HOME/deploy/configs/tmux/script/track_ai_agent_state.sh" init "$TMUX_PANE"
    status_bridge_enabled=1
}

start_tui_state_monitor() {
    [[ "$status_bridge_enabled" = "1" ]] || return 0

    local tracker_script="$HOME/deploy/configs/tmux/state-tracker/tui-output.sh"
    [[ -x "$tracker_script" ]] || die "tmux state tracker is not executable: $tracker_script"

    "$tracker_script" "$TMUX_PANE" >>"$status_log_file" 2>&1 &
    status_monitor_pid="$!"
}

write_remote_script() {
    cat >"$remote_script" <<'REMOTE_SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

remote_cwd="${1:-}"
remote_codex_bin="${2:?missing remote codex binary}"
remote_listen="${3:?missing remote listen url}"
connect_timeout="${4:-20}"
status_port="${5:-}"
empty_arg_sentinel="__CODEX_REMOTE_EMPTY_ARG__"
remote_codex_home=""
app_server_pid=""
app_server_port="${remote_listen##*:}"
app_server_cmd=()
remote_config_overrides=()

[[ "$remote_cwd" == "$empty_arg_sentinel" ]] && remote_cwd=""
[[ "$status_port" == "$empty_arg_sentinel" ]] && status_port=""

shift 5
remote_config_overrides=("$@")

probe_readyz() (
    local port="$1"
    local response

    { exec 3<>"/dev/tcp/127.0.0.1/${port}"; } 2>/dev/null || return 1
    printf 'GET /readyz HTTP/1.0\r\nHost: 127.0.0.1:%s\r\n\r\n' "$port" >&3 || return 1
    IFS= read -r -t 2 response <&3 || return 1
    [[ "$response" == HTTP/*" 200 "* ]]
)

cleanup() {
    if [[ -n "$app_server_pid" ]] && kill -0 "$app_server_pid" 2>/dev/null; then
        kill "$app_server_pid" 2>/dev/null || true
        wait "$app_server_pid" 2>/dev/null || true
    fi
}
trap cleanup EXIT INT TERM HUP

prepare_remote_codex_home() {
    remote_codex_home="$HOME/.codex-remote-status"
    mkdir -p "$remote_codex_home"

    if [[ -d "$HOME/.codex" ]]; then
        while IFS= read -r codex_item; do
            name="${codex_item##*/}"
            dest="$remote_codex_home/$name"
            [[ "$name" == "hooks.json" ]] && continue
            [[ "$name" == "plugins" && ( -e "$dest" || -L "$dest" ) ]] && continue
            ln -sfnT "$codex_item" "$dest"
        done < <(find "$HOME/.codex" -mindepth 1 -maxdepth 1)
    fi
}

if [[ -n "$status_port" ]]; then
    prepare_remote_codex_home

    cat >"$remote_codex_home/codex-remote-status-hook.sh" <<'HOOK_SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

state="${1:?usage: codex-remote-status-hook.sh init|running|idle|background|pending}"
case "$state" in
    init|running|idle|background|pending) ;;
    *) echo "invalid remote Codex status state: $state" >&2; exit 2 ;;
esac

port="${CODEX_REMOTE_STATUS_PORT:?CODEX_REMOTE_STATUS_PORT is not set}"
exec 3<>"/dev/tcp/127.0.0.1/${port}"
printf 'GET /%s HTTP/1.0\r\nHost: 127.0.0.1\r\n\r\n' "$state" >&3
while IFS= read -r _line <&3; do
    :
done || true
HOOK_SCRIPT
    chmod +x "$remote_codex_home/codex-remote-status-hook.sh"

    cat >"$remote_codex_home/hooks.json" <<'HOOKS_JSON'
{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env -u BASH_ENV bash --noprofile --norc -c 'exec \"$CODEX_HOME/codex-remote-status-hook.sh\" init' >/dev/null",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env -u BASH_ENV bash --noprofile --norc -c 'exec \"$CODEX_HOME/codex-remote-status-hook.sh\" running' >/dev/null",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env -u BASH_ENV bash --noprofile --norc -c 'exec \"$CODEX_HOME/codex-remote-status-hook.sh\" idle' >/dev/null",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
HOOKS_JSON

    export CODEX_HOME="$remote_codex_home"
    export CODEX_REMOTE_STATUS_PORT="$status_port"
fi

if [[ -n "$remote_cwd" ]]; then
    cd "$remote_cwd"
fi

case "$app_server_port" in
    ""|*[!0-9]*) echo "invalid remote app-server listen URL: $remote_listen" >&2; exit 2 ;;
esac

if (exec 9<>"/dev/tcp/127.0.0.1/${app_server_port}") 2>/dev/null; then
    echo "remote app-server port already in use: 127.0.0.1:${app_server_port}" >&2
    echo "pass --remote-port with a free port, or stop the existing remote app-server first" >&2
    exit 1
fi

app_server_cmd=("$remote_codex_bin")
if [[ -n "$status_port" ]]; then
    app_server_cmd+=(--dangerously-bypass-hook-trust)
fi
app_server_cmd+=(app-server)
for config_override in "${remote_config_overrides[@]}"; do
    app_server_cmd+=(-c "$config_override")
done
app_server_cmd+=(--listen "$remote_listen")

"${app_server_cmd[@]}" &
app_server_pid="$!"
echo "CODEX_REMOTE_APP_SERVER_PID=$app_server_pid"

deadline=$((SECONDS + connect_timeout))
while ! probe_readyz "$app_server_port"; do
    if ! kill -0 "$app_server_pid" 2>/dev/null; then
        wait "$app_server_pid"
        exit $?
    fi
    if (( SECONDS >= deadline )); then
        echo "timed out waiting for remote app-server readyz: http://127.0.0.1:${app_server_port}/readyz" >&2
        exit 1
    fi
    sleep 0.2
done
echo "CODEX_REMOTE_APP_SERVER_READY=1"
wait "$app_server_pid"
REMOTE_SCRIPT
    chmod +x "$remote_script"
}

start_status_bridge
start_tui_state_monitor
load_remote_codex_config_overrides
append_config_overrides_for_local_tui
write_remote_script

empty_ssh_arg="__CODEX_REMOTE_EMPTY_ARG__"
remote_cwd_arg="$remote_cwd"
[[ -n "$remote_cwd_arg" ]] || remote_cwd_arg="$empty_ssh_arg"
remote_status_arg="$empty_ssh_arg"
if [[ "$status_bridge_enabled" = "1" ]]; then
    remote_status_arg="$remote_status_port"
fi

ssh_cmd=(ssh -o ExitOnForwardFailure=yes -L "${local_port}:127.0.0.1:${remote_port}")
if [[ "$status_bridge_enabled" = "1" ]]; then
    ssh_cmd+=(-R "127.0.0.1:${remote_status_port}:127.0.0.1:${local_status_port}")
fi
ssh_cmd+=("${ssh_args[@]}" "$ssh_target" env -u BASH_ENV bash --noprofile --norc -s -- "$remote_cwd_arg" "$remote_codex_bin" "$remote_listen" "$connect_timeout" "$remote_status_arg")
ssh_cmd+=("${codex_config_overrides[@]}")

"${ssh_cmd[@]}" <"$remote_script" >"$log_file" 2>&1 &
ssh_pid="$!"

deadline=$((SECONDS + connect_timeout))
while true; do
    read_remote_app_server_state
    if [[ "$remote_app_server_ready" = "1" ]] && probe_app_server_ws "$local_port"; then
        break
    fi
    if ! kill -0 "$ssh_pid" 2>/dev/null; then
        echo "codex-remote: ssh/app-server process exited before the remote app-server became ready" >&2
        cat "$log_file" >&2
        exit 1
    fi
    if (( SECONDS >= deadline )); then
        echo "codex-remote: timed out waiting for remote app-server WebSocket readiness" >&2
        echo "codex-remote: local endpoint ws://127.0.0.1:${local_port} -> ${ssh_target} ${remote_listen}" >&2
        cat "$log_file" >&2
        exit 1
    fi
    sleep 0.2
done

echo "codex-remote: remote app-server ready $ssh_target ${remote_listen} -> ws://127.0.0.1:${local_port}" >&2
if [[ "$status_bridge_enabled" = "1" ]]; then
    echo "codex-remote: AI status bridge enabled for ${TMUX_PANE}" >&2
fi
set +e
"$codex_bin" \
    "${local_codex_config_args[@]}" \
    --dangerously-bypass-approvals-and-sandbox \
    --dangerously-bypass-hook-trust \
    --remote "ws://127.0.0.1:${local_port}"
codex_status=$?
set -e

if [[ "$codex_status" -ne 0 ]]; then
    echo "codex-remote: local Codex exited with status ${codex_status} while connecting to ws://127.0.0.1:${local_port}" >&2
    echo "codex-remote: SSH forwarding and remote WebSocket readiness had already succeeded; retrying may fix a startup race" >&2
    echo "codex-remote: persistent failures usually indicate a Codex version/protocol mismatch or a remote app-server crash" >&2
    if [[ -s "$log_file" ]]; then
        echo "codex-remote: remote app-server log follows:" >&2
        cat "$log_file" >&2
    fi
    exit "$codex_status"
fi

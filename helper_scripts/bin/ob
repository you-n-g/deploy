#!/usr/bin/env bash
set -euo pipefail

VAULT_NAME="markdown"
VAULT_DIR="$HOME/Downloads/markdown"

usage() {
    echo "Usage: ob <file> [file ...]" >&2
    exit 2
}

if [ "$#" -lt 1 ]; then
    usage
fi

if [ ! -d "$VAULT_DIR/.obsidian" ]; then
    echo "ob: Obsidian vault not found: $VAULT_DIR" >&2
    exit 1
fi

abs_path() {
    python3 -c 'import pathlib, sys; print(pathlib.Path(sys.argv[1]).resolve())' "$1"
}

encode_uri_component() {
    python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1]))' "$1"
}

check_linkable() {
    local src="$1" src_abs base dest

    if [ ! -f "$src" ]; then
        echo "ob: file not found: $src" >&2
        exit 1
    fi

    src_abs="$(abs_path "$src")"
    base="$(basename "$src_abs")"
    dest="$vault_abs/$base"

    if [ "$src_abs" != "$dest" ] && [ -e "$dest" ] && [ ! -L "$dest" ]; then
        echo "ob: target already exists and is not a symlink: $dest" >&2
        exit 1
    fi
}

link_into_vault() {
    local src="$1" src_abs base dest dest_target_abs

    src_abs="$(abs_path "$src")"
    base="$(basename "$src_abs")"
    dest="$vault_abs/$base"

    if [ "$src_abs" != "$dest" ]; then
        if [ -L "$dest" ]; then
            dest_target_abs="$(python3 -c 'import pathlib, sys; print(pathlib.Path(sys.argv[1]).resolve(strict=False))' "$dest")"
            if [ "$dest_target_abs" != "$src_abs" ]; then
                ln -sfn "$src_abs" "$dest"
            fi
        elif [ -e "$dest" ]; then
            echo "ob: target already exists and is not a symlink: $dest" >&2
            exit 1
        else
            ln -s "$src_abs" "$dest"
        fi
    fi

    printf '%s\n' "$base"
}

vault_abs="$(abs_path "$VAULT_DIR")"
for src in "$@"; do
    check_linkable "$src"
done

for src in "$@"; do
    link_path="$(link_into_vault "$src")"
    encoded_file="$(encode_uri_component "$link_path")"
    open "obsidian://open?vault=$VAULT_NAME&file=$encoded_file"
done

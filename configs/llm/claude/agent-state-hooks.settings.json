{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"$HOME/deploy/configs/tmux/script/claude_agent_state_hook.sh\" init'",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"$HOME/deploy/configs/tmux/script/claude_agent_state_hook.sh\" running'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"$HOME/deploy/configs/tmux/script/claude_agent_state_hook.sh\" stop'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

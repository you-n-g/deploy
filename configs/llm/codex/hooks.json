{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'AI_AGENT_STATE_SOURCE=codex-hook:session-start exec \"$HOME/deploy/configs/tmux/script/track_ai_agent_state.sh\" init'",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'AI_AGENT_STATE_SOURCE=codex-hook:user-prompt-submit exec \"$HOME/deploy/configs/tmux/script/track_ai_agent_state.sh\" running'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'AI_AGENT_STATE_SOURCE=codex-hook:stop exec \"$HOME/deploy/configs/tmux/script/track_ai_agent_state.sh\" idle'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

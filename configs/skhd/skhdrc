# Helper
# fn - 0 : osascript -e 'tell application "System Events" to set frontApp to name of first application process whose frontmost is true' \
#                      -e 'display notification frontApp with title "Current App Name for skhd"'

fn - 0 : name=$(yabai -m query --windows --window | jq -r '.app'); \
             osascript -e "display notification \"skhd name: $name\" with title \"yabai Debugger\""


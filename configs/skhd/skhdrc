# fn + 1 launches Obsidian
fn - 1 [
    "obsidian" : skhd -k "cmd - h"
    * : open -a "Obsidian"
]

# 使用 0x53 代表小键盘 1
0x53 [
    "obsidian" : skhd -k "cmd - h"
    * : open -a "Obsidian"
]


# 定义小键盘 2 (0x54) 的行为（Safari）
0x54 [
    "Safari" : skhd -k "cmd - h"      # 如果 Safari 已在前台，则隐藏
    * : open -a "Safari"              # 否则启动 Safari
]

# 定义 fn + 主键盘 2 的行为（Safari）
# 注意：fn 组合键在 skhd 中直接写 fn - <key>
fn - 2 [
    "Safari" : skhd -k "cmd - h"      # 如果 Safari 在前台，关闭当前窗口
    * : open -a "Safari"              # 否则启动 Safari
]

# 定义小键盘 3 (0x55) 的行为
0x55 [
    "Clash Verge" : skhd -k "cmd - w"
    * : open -a "Clash Verge"
]

# 定义小键盘 4 (0x56) 的行为（iTerm2）
0x56 [
    "iTerm2" : skhd -k "cmd - h"    # 如果 iTerm2 已在前台，则隐藏
    * : open -a "iTerm"            # 否则启动/切到 iTerm2
]

# 小键盘 0 (0x52) / . (0x41)
# NOTE: skhd 只能“触发动作/发送具体按键”，做不到把一个键改成“纯修饰键(按住=Fn+Cmd)”。
# 如果你是想按一下小键盘 0 来发送某个具体组合键，把下面这一行里的 <key> 换成你要的按键即可。
# 0x52 : skhd -k "fn + cmd - <key>"
# 0x41 : skhd -k "fn + cmd"

# 小键盘 . (0x41) -> Ctrl+B 再 Ctrl+G（适合 tmux 这类需要按键序列的场景）
# 0x41 : skhd -k "ctrl - b"; skhd -k "ctrl - g"
0x52 : skhd -k "ctrl - b"; skhd -k "ctrl - g"

# 定义 fn + 主键盘 4 的行为（iTerm2）
fn - 4 [
    "iTerm2" : skhd -k "cmd - h"    # 如果 iTerm2 已在前台，则隐藏
    * : open -a "iTerm"            # 否则启动/切到 iTerm2
]

# # F15: 唤醒飞书 -> Cmd+K -> 搜索 Drumstick AI -> 输入 🍗
# f15 : ~/deploy/configs/skhd/feishu-drumstick.sh

# 定义小键盘 Enter (0x4c) 的行为（切到 iTerm2 -> 发送 Enter -> 切回原程序）
# 0x4C : ~/deploy/configs/skhd/numpad-enter.sh

# F16-F19: 切到 iTerm2 对应标签页（⌥⌘1~4），发送 Enter，再切回原程序
f16 : ~/deploy/configs/skhd/numpad-enter.sh 1
f17 : ~/deploy/configs/skhd/numpad-enter.sh 2
f18 : ~/deploy/configs/skhd/numpad-enter.sh 3
f19 : ~/deploy/configs/skhd/numpad-enter.sh 4

# 定义小键盘 7 (0x59) 的行为（飞书 / Lark）
0x59 [
    "Feishu" : skhd -k "cmd - h"      # 如果飞书已在前台，则隐藏
    "Lark" : skhd -k "cmd - h"        # 国际版名字通常是 Lark
    * : open -a "Feishu" || open -a "Lark"
]

# 定义 fn + 主键盘 7 的行为（飞书 / Lark）
fn - 7 [
    "Feishu" : skhd -k "cmd - h"
    "Lark" : skhd -k "cmd - h"
    * : open -a "Feishu" || open -a "Lark"
]

# 定义 fn + 主键盘 3 的行为
# 注意：fn 组合键在 skhd 中直接写 fn - <key>
fn - 3 [
    "Clash Verge" : skhd -k "cmd - w"
    * : open -a "Clash Verge"
]

